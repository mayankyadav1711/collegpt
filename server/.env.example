# ─── COLLEGPT ENVIRONMENT VARIABLES ──────────────────────────────────────────

# Node server port (defaults to 5000)
PORT=5000

# MongoDB Connection String (Required)
# Format: mongodb+srv://<username>:<password>@<cluster>.<id>.mongodb.net/<database>
MOGOURI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# JSON Web Token (JWT) Secret Key (Required)
# Generate a strong, secure key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SEC=your_super_secret_jwt_key_here

# Gmail SMTP Authentication Details (Required for OTP & Reset Emails)
# Note: For Gmail, you MUST use a "Google App Password", not your login password.
# Setup here: https://myaccount.google.com/apppasswords
EMAIL=your_email@gmail.com
GPASS=your_gmail_app_password

# ─── OPTIONAL SECURITY CONFIGURATIONS ────────────────────────────────────────

# Allowed CORS Origins (Comma-separated list)
# If not specified, defaults to standard localhost and deployment domains.
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# Frontend Reset Password Base URL (Optional)
# If not specified, falls back to using the EMAIL env variable value.
# RESET_PASSWORD_URL=http://localhost:5173
